<h1>设置</h1>

<div class="two-col">
  <div>
    <div class="card">
      <h2>定时发布设置</h2>
      <form action="/settings/schedule" method="POST">
        <div class="form-group">
          <label>
            <input type="checkbox" name="enabled" <%= schedule.enabled ? 'checked' : '' %>>
            启用定时发布
          </label>
        </div>
        <div class="form-group">
          <label>Cron 表达式</label>
          <input type="text" name="cron" value="<%= schedule.cron %>">
          <div style="font-size:12px;color:#999;margin-top:4px">示例: <code>0 8 * * *</code> (每天早上8点)</div>
        </div>
        <div class="form-group">
          <label>每轮最多发布篇数</label>
          <input type="number" name="maxArticlesPerRun" value="<%= schedule.maxArticlesPerRun %>" min="1" max="5">
        </div>
        <div class="form-group">
          <label>偏好主题 (逗号分隔)</label>
          <input type="text" name="preferredTopics" value="<%= (schedule.preferredTopics || []).join(', ') %>" placeholder="AI, 科技, 效率工具">
        </div>
        <button type="submit" class="btn btn-primary">保存调度设置</button>
      </form>
    </div>

    <div class="card">
      <h2>RSS 订阅源</h2>
      <% if (rssSources.length === 0) { %>
        <div class="empty">暂无 RSS 源</div>
      <% } else { %>
        <ul class="rss-list">
          <% rssSources.forEach(s => { %>
            <li>
              <div>
                <strong><%= s.name %></strong>
                <div style="font-size:12px;color:#999"><%= s.url %></div>
              </div>
              <div class="inline-flex">
                <form action="/settings/rss/<%= s.id %>/toggle" method="POST" style="display:inline">
                  <button class="btn btn-sm <%= s.enabled ? 'btn-primary' : '' %>"><%= s.enabled ? '已启用' : '已禁用' %></button>
                </form>
                <form action="/settings/rss/<%= s.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('确定删除？')">
                  <button class="btn btn-danger btn-sm">删除</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
      <h3 style="font-size:16px;margin-top:12px">添加 RSS 源</h3>
      <form action="/settings/rss/add" method="POST">
        <div class="form-group">
          <label>名称</label>
          <input type="text" name="name" placeholder="例如: 36氪">
        </div>
        <div class="form-group">
          <label>RSS 地址</label>
          <input type="url" name="url" placeholder="https://rss.example.com/feed">
        </div>
        <div class="form-group">
          <label>抓取间隔 (分钟)</label>
          <input type="number" name="interval" value="60" min="10">
        </div>
        <button type="submit" class="btn btn-primary">添加</button>
      </form>
    </div>
  </div>

  <div>
    <div class="card">
      <h2>立即执行</h2>
      <p style="color:#666;margin-bottom:12px">立即触发一次完整的生成→发布管线</p>
      <form action="/settings/pipeline/run" method="POST">
        <button class="btn btn-primary">运行管线</button>
      </form>
    </div>

    <div class="card">
      <h2>配置说明</h2>
      <div style="font-size:14px;color:#555;line-height:1.8">
        <p><strong>环境变量 (.env)</strong></p>
        <ul style="padding-left:20px;margin-bottom:12px">
          <li><code>DEEPSEEK_API_KEY</code> - DeepSeek API 密钥</li>
          <li><code>WECHAT_APPID</code> - 公众号 AppID</li>
          <li><code>WECHAT_APPSECRET</code> - 公众号 AppSecret</li>
          <li><code>PORT</code> - 服务端口 (默认 3000)</li>
        </ul>
        <p><strong>管线流程</strong></p>
        <ol style="padding-left:20px">
          <li>检查是否有到定时发布的草稿 → 发布</li>
          <li>否则按偏好主题 AI 生成 → 发布</li>
          <li>否则 RSS 抓取改写 → 发布</li>
          <li>否则用默认主题生成 → 发布</li>
        </ol>
      </div>
    </div>
  </div>
</div>
